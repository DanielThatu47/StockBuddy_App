# ================================================
# StockBuddy Spring Boot — Environment Variables
# Copy this file to .env or set these in your
# environment / deployment platform.
# ================================================

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/stockbuddy?retryWrites=true&w=majority
MONGO_DB=stockbuddy

# JWT — use a long random string (32+ characters)
JWT_SECRET=replace-with-a-long-random-secret-string

# Cloudinary — from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# URL of the external prediction model API
MODEL_API_URL=http://localhost:8000

# Comma-separated list of admin email addresses
ADMIN_EMAILS=admin@stockbuddy.com
